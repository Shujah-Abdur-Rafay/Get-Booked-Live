# ── Supabase ────────────────────────────────────────────────────────────────
# These must be prefixed with VITE_ to be available in the browser bundle.
# Get these from Supabase Dashboard > Settings > API
VITE_SUPABASE_URL="https://<your-project-ref>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-key>"

# ── External APIs ─────────────────────────────────────────────────────────────
# Exchange rate API key (https://app.exchangerate-api.com/keys)
VITE_EXCHANGE_RATE_API_KEY="<your-api-key>"

# ── Edge Functions (DO NOT EXPOSE TO FRONTEND) ────────────────────────────────
# These keys should only exist in Supabase Vault / Edge Function secrets.
# DO NOT ADD THEM HERE to avoid accidental frontend exposure.
# -> SUPABASE_SERVICE_ROLE_KEY
# -> STRIPE_SECRET_KEY
# -> STRIPE_WEBHOOK_SECRET
